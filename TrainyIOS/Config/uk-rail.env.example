# Copy to TrainyIOS/Config/uk-rail.env for future UK backend worker smoke checks.
# Start at the National Rail Data Portal: https://opendata.nationalrail.co.uk/
# Darwin Push requires a backend Kafka consumer path before a fixture smoke can run.
# No current local smoke script consumes this file.
UK_DARWIN_KAFKA_BOOTSTRAP=
UK_DARWIN_TOPIC=
UK_DARWIN_USERNAME=
UK_DARWIN_PASSWORD=
UK_DARWIN_CONSUMER_GROUP=
