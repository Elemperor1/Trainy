{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "SwiftPM: Describe",
      "type": "shell",
      "command": "swift",
      "args": ["package", "describe"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Xcode: Build iOS App Wrapper",
      "detail": "Build the Trainy iOS app and TrainyCore package through Xcode with the iPhone Simulator SDK.",
      "type": "shell",
      "command": "scripts/build-ios.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$swiftc",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Xcode: Test iOS App Wrapper",
      "type": "shell",
      "command": "xcodebuild",
      "args": [
        "test",
        "-project",
        "TrainyIOS/Trainy.xcodeproj",
        "-scheme",
        "TrainyTests",
        "-destination",
        "platform=iOS Simulator,name=iPhone 17",
        "-derivedDataPath",
        "/private/tmp/trainy-derived",
        "-clonedSourcePackagesDirPath",
        "/private/tmp/trainy-source-packages",
        "-packageCachePath",
        "/private/tmp/trainy-swiftpm-cache",
        "CODE_SIGNING_ALLOWED=NO",
        "TRAINY_SOURCE_PACKAGES_DIR=/private/tmp/trainy-source-packages"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$swiftc",
      "group": "test"
    }
  ]
}
